# compose.example.env — Example environment for docker-compose / podman-compose
# Usage:
#   cp compose.example.env .env
#   $EDITOR .env
#   docker compose up
#   # or
#   podman-compose up

# Version tag of the Neuralgentics release to use.
NEURALGENTICS_VERSION=v0.2.0

# Database connection.
NEURALGENTICS_DB_PORT=6000
NEURALGENTICS_DB_USER=postgres
NEURALGENTICS_DB_PASSWORD=neuralgentics   # Change for production!
NEURALGENTICS_DB_NAME=neuralgentics

# Embedding device: 'cpu' or 'cuda' (requires nvidia-container-toolkit).
NEURALGENTICS_EMBED_DEVICE=cpu