# compose.example.env — Example environment for docker-compose / podman-compose
# Usage:
#   cp compose.example.env .env
#   $EDITOR .env
#   docker compose up
#   # or
#   podman-compose up

# Version tag of the Neuralgentics release to use.
NEURALGENTICS_VERSION=v0.2.0

# Database connection.
NEURALGENTICS_DB_PORT=6200
NEURALGENTICS_DB_USER=postgres
NEURALGENTICS_DB_PASSWORD=neuralgentics   # Change for production!
NEURALGENTICS_DB_NAME=neuralgentics

# Embedding device: 'cpu' or 'cuda' (requires nvidia-container-toolkit).
NEURALGENTICS_EMBED_DEVICE=cpu

# Embedding dtype: 'fp32' | 'fp16' | 'int8' (v0.9.6+).
#   - fp16: half-precision, recommended on CUDA (gpu).
#   - int8: 8-bit quantized, recommended on CPU (smallest + fastest, ~1% quality loss).
#   - fp32: full precision, largest + slowest (debugging only).
# `neuralgentics init` resolves this from --quantize/--device; override here
# to force a dtype regardless of the CLI. Default: int8 on CPU, fp16 on GPU.
NEURALGENTICS_EMBED_DTYPE=int8

# Lazy-load (v0.9.6+):
#   EAGER=false  → load model on first embed call (default; saves memory when idle).
#   EAGER=true   → load model at sidecar start (--no-lazy-load).
# Use EAGER=true if cold-load latency (2-15s) is unacceptable.
EAGER=false

# Minutes of idleness before the lazy sidecar unloads the model to free memory.
# Only applies when EAGER=false. Default: 5 minutes.
IDLE_MIN=5

# Sidecar HTTP /status port (for cold-load detection from the plugin).
# Exposes {loaded_models, last_used, dtype, device, idle_min, eager}.
NEURALGENTICS_SIDECAR_STATUS_PORT=50052

# Embedding model: bge-m3 (multilingual 8K), bge-large (English 512), or all-MiniLM-L6-v2 (fast 384)
NEURALGENTICS_EMBED_MODEL=bge-m3