# compose.example.env — Example environment for the neuralgentics PostgreSQL stack
#
# Shipped inside the @veedubin/neuralgentics npm package.
# Usage:
#   cp compose.example.env .env
#   $EDITOR .env   # change the password!
#   docker compose up -d
#   # or
#   podman-compose up -d
#
# ── Multi-instance (run several stacks side by side) ──────────────────────
# Copy this file, set a different NEURALGENTICS_STACK_NAME and
# NEURALGENTICS_DB_PORT, and you can run a second stack alongside the
# first (e.g. one per project). They share the same docker-compose.yml
# but get distinct container/volume/network names and host ports:
#   cp compose.example.env .env.proj2
#   # edit .env.proj2:
#   #   NEURALGENTICS_STACK_NAME=neuralgentics-proj2
#   #   NEURALGENTICS_DB_PORT=6300
#   podman-compose --env-file .env.proj2 up -d
# Then run `neuralgentics --db-start --db-user <name>` (or answer the
# interactive prompt) once per stack to create its first database user.

# ── Stack identity ─────────────────────────────────────────────────────────
# Names the container ("${STACK}-db"), the named volume ("${STACK}-db"),
# and the bridge network ("${STACK}-net"). Set a unique value per stack.
NEURALGENTICS_STACK_NAME=neuralgentics

# Version tag of the Neuralgentics release to use.
NEURALGENTICS_VERSION=latest

# Database connection — these become the DSN you enter in --init-project.
# NEURALGENTICS_DB_PORT is the HOST port mapped to the container's 5432.
# Each side-by-side stack MUST use a distinct host port.
NEURALGENTICS_DB_PORT=6200
NEURALGENTICS_DB_USER=neuralgentics
NEURALGENTICS_DB_PASSWORD=neuralgentics   # Change for production!
NEURALGENTICS_DB_NAME=neuralgentics

# ── OPTIONAL: sidecar (embedding service) settings ───────────────────────────
# Only relevant if you uncomment the sidecar service in docker-compose.yml.

# Embedding device: 'cpu' or 'cuda' (requires nvidia-container-toolkit).
NEURALGENTICS_EMBED_DEVICE=cpu

# Embedding dtype: 'fp32' | 'fp16' | 'int8'.
#   - fp16: half-precision, recommended on CUDA (gpu).
#   - int8: 8-bit quantized, recommended on CPU (smallest + fastest, ~1% quality loss).
#   - fp32: full precision, largest + slowest (debugging only).
NEURALGENTICS_EMBED_DTYPE=int8

# Lazy-load: EAGER=false loads model on first embed (default; saves memory).
EAGER=false

# Minutes of idleness before the lazy sidecar unloads the model.
IDLE_MIN=5

# Sidecar HTTP /status port.
NEURALGENTICS_SIDECAR_STATUS_PORT=50052

# Embedding model: bge-m3 (multilingual 8K), bge-large (English 512),
# or all-MiniLM-L6-v2 (fast 384).
NEURALGENTICS_EMBED_MODEL=bge-m3