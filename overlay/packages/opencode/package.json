{
  "name": "@veedubin/neuralgentics",
  "version": "0.14.5",
  "description": "Neuralgentics OpenCode plugin — agent personas, skills, routing enforcement, and MCP tools.",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "bin": {
    "neuralgentics": "./dist/cli.js"
  },
  "files": [
    "dist/",
    ".opencode/"
  ],
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./library": {
      "import": "./dist/neuralgentics/index.js",
      "types": "./dist/neuralgentics/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test:e2e": "node e2e_test.mjs",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "neuralgentics",
    "agent",
    "orchestration",
    "boomerang"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Veedubin/neuralgentics",
    "directory": "overlay/packages/opencode"
  },
  "homepage": "https://github.com/Veedubin/neuralgentics#readme",
  "bugs": {
    "url": "https://github.com/Veedubin/neuralgentics/issues"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.15.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "opencode": "^1.15.0"
  }
}
