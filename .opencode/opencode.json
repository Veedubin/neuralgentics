{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama-cloud": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Cloud",
      "options": {
        "baseURL": "https://ollama.com/v1"
      },
      "models": {
        "kimi-k2.6:cloud": {
          "name": "Kimi K2.6 (Cloud)"
        },
        "glm-5.1:cloud": {
          "name": "GLM 5.1 (Cloud)"
        },
        "deepseek-v4-pro:cloud": {
          "name": "DeepSeek V4 Pro (Cloud)"
        },
        "devstral-2:123b-cloud": {
          "name": "Devstral 2 (Cloud)"
        },
        "deepseek-v4-flash:cloud": {
          "name": "DeepSeek V4 Flash (Cloud)"
        },
        "qwen3-coder-next:cloud": {
          "name": "Qwen3 Coder Next (Cloud)"
        },
        "minimax-m2.7:cloud": {
          "name": "MiniMax M2.7 (Cloud)"
        },
        "gemma4:31b-cloud": {
          "name": "Gemma 4 31B (Cloud)"
        },
        "qwen3.5:cloud": {
          "name": "Qwen 3.5 (Cloud)"
        },
        "devstral-small-2:24b-cloud": {
          "name": "Devstral Small 2 (Cloud)"
        }
      }
    },
    "dmr-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Docker Model Runner (Local)",
      "options": {
        "baseURL": "http://localhost:12434/engines/v1"
      },
      "models": {
        "ai/qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B (Local)"
        },
        "ai/llama3.2:3b": {
          "name": "Llama 3.2 3B (Local)"
        },
        "ai/devstral-small-2:24b": {
          "name": "Devstral Small 2 24B (Local)"
        }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "headers": {
          "Authorization": "Bearer {env:OPENROUTER_API_KEY}"
        }
      },
      "models": {
        "anthropic/claude-3.5-sonnet": {
          "name": "Claude 3.5 Sonnet"
        },
        "openai/gpt-4o": {
          "name": "GPT-4o"
        },
        "google/gemini-pro-1.5": {
          "name": "Gemini Pro 1.5"
        },
        "meta-llama/llama-3.1-405b-instruct": {
          "name": "Llama 3.1 405B"
        },
        "mistralai/mistral-large-latest": {
          "name": "Mistral Large"
        }
      }
    },
    "ollama": {
      "name": "Ollama Cloud",
      "api": "openai",
      "options": {
        "baseURL": "https://ollama.com/v1",
        "apiKey": "YOUR_OLLAMA_CLOUD_API_KEY"
      },
      "models": {
        "kimi-k2.6": {
          "name": "Kimi K2.6 (Cloud)",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        },
        "glm-5.1": {
          "name": "GLM 5.1 (Cloud)",
          "limit": {
            "context": 200000,
            "output": 131072
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (Cloud)",
          "limit": {
            "context": 1000000,
            "output": 384000
          }
        },
        "devstral-2:123b": {
          "name": "Devstral 2 123B (Cloud)",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (Cloud)",
          "limit": {
            "context": 1000000,
            "output": 384000
          }
        },
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next (Cloud)",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        },
        "minimax-m2.7": {
          "name": "MiniMax M2.7 (Cloud)",
          "limit": {
            "context": 204800,
            "output": 131072
          }
        },
        "minimax-m3": {
          "name": "MiniMax M3 (Cloud)",
          "limit": {
            "context": 512000,
            "output": 128000
          }
        },
        "gemma4:31b": {
          "name": "Gemma 4 31B (Cloud)",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "qwen3.5": {
          "name": "Qwen 3.5 (Cloud)",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        },
        "devstral-small-2:24b": {
          "name": "Devstral Small 2 24B (Cloud)",
          "limit": {
            "context": 128000,
            "output": 128000
          }
        },
        "glm-5.2": {
          "name": "GLM 5.2 (Cloud)",
          "limit": {
            "context": 976000,
            "output": 131072
          }
        },
        "mistral-large-3:675b": {
          "name": "Mistral Large 3 675B (Cloud)",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        }
      }
    }
  },
  "autoupdate": false,
  "mcp": {
    "memini-ai-dev": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "/home/jcharles/Projects/MCP-Servers/memini-ai-dev",
        "memini-ai",
        "--stdio"
      ],
      "environment": {
        "MEMINI_DB_URL": "postgresql://postgres:password@localhost:5434/postgres",
        "MEMINI_TRUST_ENGINE": "true",
        "MEMINI_MEMORY_GRAPH": "true",
        "MEMINI_KG_ENABLED": "true",
        "THOUGHT_CHAINS": "true",
        "MEMINI_PROJECT_ID": "neuralgentics"
      },
      "timeout": 60000,
      "enabled": true
    },
    "github-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@anthropic/mcp-server-playwright"
      ],
      "enabled": true
    },
    "searxng": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-searxng"
      ],
      "environment": {
        "SEARXNG_URL": "http://localhost:8080"
      },
      "enabled": true
    },
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "enabled": true
    }
  },
  "tool_output": {
    "max_lines": 10000,
    "max_bytes": 512000
  },
  "plugin": [
    "@veedubin/neuralgentics",
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "lsp": {
    "typescript": {
      "disabled": false,
      "command": [
        "npx",
        "typescript-language-server",
        "--stdio"
      ]
    },
    "pyright": {
      "disabled": false,
      "command": [
        "npx",
        "pyright-langserver",
        "--stdio"
      ]
    }
  },
  "formatter": {
    "ruff": {
      "command": [
        "uvx",
        "ruff",
        "format",
        "$FILE"
      ]
    },
    "prettier": {
      "disabled": false
    }
  },
  "instructions": [
    "AGENTS.md"
  ],
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },
  "small_model": "ollama/devstral-small-2:24b"
}
