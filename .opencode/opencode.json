{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "dmr-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Docker Model Runner (Local)",
      "options": {
        "baseURL": "http://localhost:12434/engines/v1"
      },
      "models": {
        "ai/qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B (Local)"
        },
        "ai/llama3.2:3b": {
          "name": "Llama 3.2 3B (Local)"
        },
        "ai/devstral-small-2:24b": {
          "name": "Devstral Small 2 24B (Local)"
        }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "headers": {
          "Authorization": "Bearer {env:OPENROUTER_API_KEY}"
        }
      },
      "models": {
        "anthropic/claude-3.5-sonnet": {
          "name": "Claude 3.5 Sonnet"
        },
        "openai/gpt-4o": {
          "name": "GPT-4o"
        },
        "google/gemini-pro-1.5": {
          "name": "Gemini Pro 1.5"
        },
        "meta-llama/llama-3.1-405b-instruct": {
          "name": "Llama 3.1 405B"
        },
        "mistralai/mistral-large-latest": {
          "name": "Mistral Large"
        }
      }
    },
    "ollama": {
      "name": "Ollama Cloud",
      "api": "openai",
      "options": {
        "baseURL": "https://ollama.com/v1",
        "apiKey": "{env:OLLAMA_API_KEY}"
      },
      "models": {
        "kimi-k2.6": {
          "name": "Kimi K2.6 (Cloud)",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        },
        "glm-5.1": {
          "name": "GLM 5.1 (Cloud)",
          "limit": {
            "context": 200000,
            "output": 131072
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (Cloud)",
          "limit": {
            "context": 1000000,
            "output": 384000
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (Cloud)",
          "limit": {
            "context": 1000000,
            "output": 384000
          }
        },
        "minimax-m2.7": {
          "name": "MiniMax M2.7 (Cloud)",
          "limit": {
            "context": 204800,
            "output": 131072
          }
        },
        "minimax-m3": {
          "name": "MiniMax M3 (Cloud)",
          "limit": {
            "context": 512000,
            "output": 128000
          }
        },
        "gemma4:31b": {
          "name": "Gemma 4 31B (Cloud)",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "glm-5.2": {
          "name": "GLM 5.2 (Cloud)",
          "limit": {
            "context": 976000,
            "output": 131072
          }
        },
        "mistral-large-3:675b": {
          "name": "Mistral Large 3 675B (Cloud)",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        }
      }
    },
    "openai": {
      "name": "OpenAI",
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "gpt-4o": {
          "name": "GPT-4o",
          "limit": { "context": 128000, "output": 16384 }
        },
        "gpt-4.1": {
          "name": "GPT-4.1",
          "limit": { "context": 1047576, "output": 32768 }
        },
        "o3-mini": {
          "name": "o3-mini",
          "limit": { "context": 200000, "output": 100000 }
        }
      }
    },
    "anthropic": {
      "name": "Anthropic",
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-20250514": {
          "name": "Claude Sonnet 4",
          "limit": { "context": 200000, "output": 16384 }
        },
        "claude-3-5-haiku-latest": {
          "name": "Claude 3.5 Haiku",
          "limit": { "context": 200000, "output": 8192 }
        }
      }
    },
    "google": {
      "name": "Google",
      "options": {
        "apiKey": "{env:GOOGLE_API_KEY}"
      },
      "models": {
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash",
          "limit": { "context": 1000000, "output": 65536 }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": { "context": 1000000, "output": 65536 }
        }
      }
    },
    "groq": {
      "name": "Groq",
      "options": {
        "apiKey": "{env:GROQ_API_KEY}"
      },
      "models": {
        "llama-3.3-70b-versatile": {
          "name": "Llama 3.3 70B (Groq)",
          "limit": { "context": 128000, "output": 32768 }
        }
      }
    },
    "kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kimi (Moonshot)",
      "options": {
        "baseURL": "https://api.moonshot.cn/v1",
        "apiKey": "{env:KIMI_API_KEY}"
      },
      "models": {
        "kimi-k2": {
          "name": "Kimi K2 (Direct)",
          "limit": { "context": 262144, "output": 262144 }
        }
      }
    },
    "minimax": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax",
      "options": {
        "baseURL": "https://api.minimax.io/v1",
        "apiKey": "{env:MINIMAX_API_KEY}"
      },
      "models": {
        "MiniMax-M3": {
          "name": "MiniMax M3",
          "limit": { "context": 512000, "output": 128000 }
        }
      }
    },
    "mammoth": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mammoth AI",
      "options": {
        "baseURL": "https://api.mammouth.ai/v1",
        "apiKey": "{env:MAMMOTH_API_KEY}"
      },
      "models": {
        "gpt-4.1": {
          "name": "GPT-4.1 (via Mammoth)",
          "limit": { "context": 1047576, "output": 32768 }
        },
        "glm-5.2": {
          "name": "GLM 5.2 (via Mammoth)",
          "limit": { "context": 1048576, "output": 131072 }
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6 (via Mammoth)",
          "limit": { "context": 262144, "output": 262144 }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (via Mammoth)",
          "limit": { "context": 1000000, "output": 128000 }
        },
        "mammouth-recommended": {
          "name": "Mammoth Recommended (auto-curated)",
          "limit": { "context": 1048576, "output": 131072 }
        }
      }
    }
  },
  "autoupdate": false,
  "mcp": {
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "enabled": true
    },
    "duckdb": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-motherduck",
        "--db-path",
        ":memory:",
        "--read-write",
        "--allow-switch-databases"
      ],
      "enabled": false
    },
    "redis": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@gongrzhe/server-redis-mcp",
        "redis://localhost:6379"
      ],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "calculator": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@wrtnlabs/calculator-mcp"
      ],
      "enabled": false
    },
    "prefect": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "prefect-mcp",
        "prefect-mcp-server"
      ],
      "enabled": false
    },
    "mlflow-mcp": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--with",
        "mlflow[mcp]>=3.5.1",
        "mlflow",
        "mcp",
        "run"
      ],
      "environment": {
        "MLFLOW_TRACKING_URI": "http://localhost:5001"
      },
      "enabled": false
    },
    "doc2png": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "doc2png"
      ],
      "enabled": false
    },
    "github-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "memini-ai-dev": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "/home/jcharles/Projects/MCP-Servers/memini-ai-dev",
        "memini-ai",
        "--stdio"
      ],
      "environment": {
        "MEMINI_DB_URL": "postgresql://postgres:password@localhost:5434/postgres",
        "MEMINI_VECTOR_BACKEND": "postgres-external",
        "MEMINI_EMBEDDING_DIM": "384",
        "TRUST_ENGINE": "true",
        "MEMORY_GRAPH": "true",
        "KG_ENABLED": "true",
        "TIERED_LOADING": "true",
        "AUTO_EXTRACT": "true",
        "PRECOMPRESS": "true",
        "USER_MODELING": "true",
        "DECAY_ENABLED": "true",
        "MULTI_PEER_ENABLED": "true",
        "DIALECTIC_ENABLED": "true",
        "THOUGHT_CHAINS": "true",
        "DB_SSLMODE": "disable",
        "MEMINI_PROJECT_ID": "neuralgentics"
      },
      "timeout": 60000,
      "enabled": true
    },
    "neuralgentics-sidecar": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@veedubin/neuralgentics-sidecar@latest"
      ],
      "environment": {
        "NEURALGENTICS_SIDECAR_HOST": "localhost",
        "NEURALGENTICS_SIDECAR_STATUS_PORT": "50052"
      },
      "timeout": 60000,
      "enabled": false
    },
    "videre-mcp": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "videre-mcp[vision]==0.3.0",
        "videre-mcp"
      ],
      "environment": {
        "MEMINI_IMAGE_SEARCH_ENABLED": "false",
        "MEMINI_IMAGE_DIR": "/home/jcharles/.memini-ai/images"
      },
      "enabled": true,
      "timeout": 120000
    },
    "searxng": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-searxng"
      ],
      "environment": {
        "SEARXNG_URL": "http://localhost:8080"
      },
      "enabled": true
    }
  },
  "tool_output": {
    "max_lines": 10000,
    "max_bytes": 512000
  },
  "plugin": [
    "@veedubin/neuralgentics",
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "lsp": {
    "typescript": {
      "disabled": false,
      "command": [
        "npx",
        "typescript-language-server",
        "--stdio"
      ]
    },
    "pyright": {
      "disabled": false,
      "command": [
        "npx",
        "pyright-langserver",
        "--stdio"
      ]
    }
  },
  "formatter": {
    "ruff": {
      "command": [
        "uvx",
        "ruff",
        "format",
        "$FILE"
      ]
    },
    "prettier": {
      "disabled": false
    }
  },
  "instructions": [
    "AGENTS.md"
  ],
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },
  "small_model": "ollama/minimax-m3"
}
