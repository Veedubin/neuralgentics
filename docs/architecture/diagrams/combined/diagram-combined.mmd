graph LR
    %% ============================================================
    %% NEURALGENTICS — END-TO-END ARCHITECTURE
    %% Single flat LR layout, no nested TB subgraphs.
    %% Each row of the diagram is a step in the pipeline.
    %% ============================================================

    %% ----- OpenCode column -----
    subgraph OC["OPENCODE — 9-STEP PROTOCOL"]
        direction LR
        S1["1. PROMPT"]
        S2["2. THOUGHT CHAIN"]
        S3["3. DECOMPOSE"]
        S4["4. ROUTE"]
        S5["5. CONTEXT PKG"]
        S1 --> S2 --> S3 --> S4 --> S5
    end

    %% ----- Broker column -----
    subgraph BK["MCP BROKER — RBAC"]
        direction LR
        B1["REQUEST"]
        B2{"ROLE<br/>CHECK"}
        B3["DENY"]
        B4["CATALOG<br/>-95% tokens"]
        B5["JACCARD<br/>match"]
        B6["EXPAND<br/>stdio/HTTP"]
        B7["JSON-RPC"]
        B8["EXECUTE"]
        B1 --> B2
        B2 -->|"denied"| B3
        B2 -->|"allowed"| B4 --> B5 --> B6
        B6 --> B7
        B6 --> B8
    end

    %% ----- Agent work loop column -----
    subgraph AG["SUB-AGENT WORK LOOP"]
        direction LR
        A1["6a. TASK()<br/>dispatch"]
        A2["6b. SPECIALIST<br/>coder/architect/tester"]
        A3{"7. GATES<br/>lint&rarr;type&rarr;test"}
        A4["BLOCK<br/>re-dispatch"]
        A1 --> A2 --> A3
        A3 -->|"FAIL"| A4 --> A2
    end

    %% ----- Improve + wrap-up column -----
    subgraph IW["IMPROVE + WRAP-UP"]
        direction LR
        I1["8a. IMPROVE<br/>patterns"]
        I2["8b. DOCS<br/>TASKS.md"]
        I3["9. SAVE<br/>memini-core"]
        I4{"More?"}
        I5["DONE"]
        A3 -->|"PASS"| I1 --> I2 --> I3 --> I4
        I4 -->|"YES"| S4
        I4 -->|"NO"| I5
    end

    %% ----- Memory sink column -----
    subgraph MM["MEMINI-AI — Trust-Weighted Memory"]
        direction LR
        M1["STORE/<br/>QUERY"]
        M2["PGVECTOR<br/>384-dim"]
        M1 --> M2
    end

    %% ----- External -----
    U["USER"]
    EXT["EXTERNAL<br/>MCPs"]

    %% ----- Cross-column flow -----
    U --> S1
    S5 --> B1
    B8 --> A1
    B6 -.->|"MCP<br/>boundary"| EXT
    A2 -->|"fetch /<br/>wrap-up"| M1
    S2 -->|"chain<br/>persisted"| M1
    I3 -->|"memory_id"| M1

    %% ----- Classes -----
    classDef userNode fill:#444,stroke:#222,color:#ccc
    classDef orchNode fill:#5B7FA5,stroke:#3A5A7A,color:#fff
    classDef agentNode fill:#C07030,stroke:#8B4F20,color:#fff
    classDef decNode fill:#D4A050,stroke:#8B4F20,color:#222
    classDef denyNode fill:#A03030,stroke:#6B2020,color:#fff
    classDef termNode fill:#4A8C4A,stroke:#2D6B2D,color:#fff
    classDef memNode fill:#4A8C4A,stroke:#2D6B2D,color:#fff
    classDef brkNode fill:#C07030,stroke:#8B4F20,color:#fff
    classDef extNode fill:#888,stroke:#555,color:#fff

    class U userNode
    class S1,S2,S3,S4,S5,I1,I2,I3 orchNode
    class A1,A2,B8 agentNode
    class A3,B2,I4 decNode
    class A4,B3 denyNode
    class I5 termNode
    class M1,M2 memNode
    class B1,B4,B5,B6 brkNode
    class EXT extNode
