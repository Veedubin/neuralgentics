# ─────────────────────────────────────────────────────────────────────────────
# Sample .env for neuralgentics — used by `bash install.sh --existing` to
# skip auto-creating a PostgreSQL container. Drop this at:
#
#     $PWD/.neuralgentics/.env
#
# (or wherever your NEURALGENTICS_DATA_DIR is — see install.sh --help).
#
# Required keys (all 5 must be present, no defaults):
#   POSTGRES_HOST       — hostname or IP of your PostgreSQL server
#   POSTGRES_PORT       — port (default 6200 for the auto-created container,
#                         5432 for a stock postgres install)
#   POSTGRES_USER       — database role
#   POSTGRES_PASSWORD   — role password
#   POSTGRES_DB         — database name
#
# The install will refuse to proceed with --existing if any of these are
# missing or commented out.
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT="6200"
POSTGRES_USER="neuralgentics"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="neuralgentics"

# ─── Embedding Sidecar (T-IMPL-SIDECAR-002 through 008) ─────────────────
# NEURALGENTICS_EMBED_DEVICE — "cpu" (default, safe) or "cuda" (fast, needs free VRAM)
NEURALGENTICS_EMBED_DEVICE=cpu
# NEURALGENTICS_EMBED_DTYPE — "fp32" (default, full precision) or "fp16" (halves VRAM on GPU)
NEURALGENTICS_EMBED_DTYPE=fp32
# NEURAL_EMBED_ADDR — gRPC listen address (default Unix socket)
NEURAL_EMBED_ADDR=unix:///tmp/neuralgentics-embed.sock
# EMBEDDING_MODE — "auto" (default, dual-write) or "primary" or "sidecar"
EMBEDDING_MODE=auto
# MEMINI_EMBEDDING_ADDR — Go backend's view of the sidecar address (should match NEURAL_EMBED_ADDR)
MEMINI_EMBEDDING_ADDR=unix:///tmp/neuralgentics-embed.sock
# SIDECAR_AUTO_START — experimental, when true Go backend attempts to spawn sidecar (v0.9.0)
SIDECAR_AUTO_START=false
# SIDECAR_ENV_FILE — path to env file consumed by sidecar.sh
SIDECAR_ENV_FILE=
