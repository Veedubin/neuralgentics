# ─── Dependencies (created by `uv` / `npm install` — never commit) ───────────
node_modules/
.venv/
venv/
env/
.secrets-venv/
__pycache__/
*.pyc
*.pyo

# ─── Build artifacts ──────────────────────────────────────────────────────────
dist/
build/
# mkdocs build output (deployed to gh-pages branch)
site/
*.egg-info/
*.tsbuildinfo

# ─── Go backend build output (built from source via `go build`) ──────────────
packages/backend-go/neuralgentics-backend
packages/backend-go/neuralgentics-backend.exe
packages/backend-go/backend
packages/backend-go/backend.exe
*.tar.gz               # release tarballs (built by CI; never commit)

# ─── Caches (auto-regenerated, multi-GB if committed) ────────────────────────
.mypy_cache/
.pytest_cache/
.ruff_cache/
.go-build/
*.log

# ─── Generated proto files (commit only the .proto sources) ──────────────────
*.pb.go.bak

# ─── Lock files we explicitly don't want (we keep bun.lock) ──────────────────
uv.lock

# ─── Vendored upstream (deleted; fetched on demand if needed) ────────────────
opencode-base/

# ─── Local TLS certs (NEVER publish; rotate if leaked) ───────────────────────
certs/

# ─── Install-time data directory (per-user runtime data; never commit) ────────
.neuralgentics/

# ─── Working tree noise ──────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/

# ─── Environment variables (contains secrets — never commit) ─────────────────
.env
.env.local
.env.*.local
!.env.example

# ─── Internal session artifacts (local-only, NOT for the public repo) ────────
# Session handoff + active task list (orchestrator working state, not docs)
HANDOFF.md
CONTEXT.md
TASKS.md

# Internal design notes, roadmaps, debug investigations (kept locally for
# reference; not user-facing documentation, not in mkdocs nav)
docs/AGENT_REGISTRATION_RESEARCH.md
docs/ARCHITECTURE_PLAN_V5.md
docs/BGE_GPU_OOM_INVESTIGATION.md
docs/DESIGN_*.md
docs/GO_MEMORY_PLAN.md
docs/NEURALGENTICS_PATCHES.md
docs/design/session-22-*.md
docs/design/session-23-*.md
docs/design/session-26-*.md
docs/design/session-27-*.md
docs/design/session-28-*.md
docs/design/session-29-*.md
docs/roadmap-v0.1.0*.md